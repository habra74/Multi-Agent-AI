# ============================================================
# .env.example — 투자 분석 시스템 환경변수 예시
# ============================================================
# 사용법:
#   cp .env.example .env
#   .env 파일을 편집한 후 앱을 실행하세요.
#
# 주의:
#   .env 파일은 절대 Git에 커밋하지 마세요 (.gitignore에 포함)
# ============================================================

# ── LLM (Anthropic Claude) ───────────────────────────────────
# 없으면 rule-based 모드로 동작 (품질 낮음)
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── 이메일 (SMTP) ─────────────────────────────────────────────
# Gmail 기준:
#   - SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
#   - 앱 비밀번호 발급: https://myaccount.google.com/apppasswords
#   - 2단계 인증이 활성화된 Google 계정 필요
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SENDER_EMAIL=your_email@gmail.com

# 기본 수신 이메일 (대시보드 → 이메일 설정에서 변경 가능)
RECIPIENT_EMAIL=recipient@example.com

# ── 스케줄러 ──────────────────────────────────────────────────
# 매일 자동 분석 실행 시각 (24시간 형식, Asia/Seoul 기준)
# 대시보드 → 이메일 설정에서 변경 가능
SCHEDULER_TIME=07:00

# ── 웹 대시보드 URL ───────────────────────────────────────────
# 로컬 실행 시:
#   BASE_URL=http://localhost:8501
#
# 클라우드 배포 (포트 직접 오픈):
#   BASE_URL=http://<서버IP>:8501
#
# Nginx + HTTPS (glowbuff 도메인):
#   BASE_URL=https://dashboard.glowbuff.com
#
# 이 값이 이메일의 "대시보드 열기" 버튼 링크로 사용됩니다.
# localhost 가 아닌 값으로 설정하면 이메일에서 로컬 실행 안내가 자동으로 숨겨집니다.
# 대시보드 → 이메일 설정에서도 변경 가능합니다.
BASE_URL=http://localhost:8501

# ── Docker 배포 시 추가 설정 (선택) ──────────────────────────
# DB 경로를 외부 볼륨 마운트 경로로 변경하려면 아래 주석 해제
# DB_PATH=/app/db/investment.db
